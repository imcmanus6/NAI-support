# ── This product's own database ───────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/support_ai

# ── Briefly integration (the /api/v1 boundary) ────────────────────────────────
# Base URL of the Briefly API and a hub-scoped API key minted in Briefly settings.
BRIEFLY_API_URL=http://localhost:3001
BRIEFLY_API_KEY=bk_live_xxxxxxxxxxxxxxxxxxxxxxxx

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Admin ─────────────────────────────────────────────────────────────────────
# Gate for the operator admin API/UI. Required — the admin routes are locked until set.
ADMIN_TOKEN=choose-a-strong-token

# Read-only connection to the host's live DB (a replica is ideal) — enables the
# agent to answer "why can't I access X". For the Briefly dogfood, point at Briefly's DB.
SOFTWARE_DB_URL=postgres://readonly@replica:5432/briefly

# ── External-customer auth ────────────────────────────────────────────────────
# Shared secret used to verify the identity token minted by the host product.
# MUST match Briefly's SUPPORT_TOKEN_SECRET exactly, and the issuer must match
# Briefly's SUPPORT_TOKEN_ISSUER (default "briefly"). See lib/customerAuth.ts.
CUSTOMER_TOKEN_ISSUER=briefly
CUSTOMER_TOKEN_SECRET=replace-me-must-match-briefly

PORT=4000

# ── Frontend build-time (apps/widget + apps/admin) ────────────────────────────
# Where the browser apps reach the API. Leave UNSET for local dev (the Vite proxy
# forwards /api and /admin to localhost:4000). In production set it to the deployed
# API origin, e.g. https://api.nai.dev — set it in each app's build environment.
# VITE_API_URL=https://api.nai.dev

# ── Blink tools-in (Direction A) — Briefly's Blink connects to NAI's /mcp endpoint,
#    authenticated with ADMIN_TOKEN. Scope the MCP server to one client (blank = oldest):
MCP_CLIENT_ID=

# ── Context Engine (Direction B) — NAI pulls Briefly's search_context over MCP,
#    scoped by a Context Pack. Use a pack-scoped bk_live key. Blank = local search.
BRIEFLY_MCP_URL=https://api.brief-ly.com/api/mcp
BRIEFLY_MCP_KEY=
